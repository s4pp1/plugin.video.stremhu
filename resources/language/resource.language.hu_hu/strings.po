#  Settings
msgctxt "#30000"
msgid "General"
msgstr "Általános"

msgctxt "#30100"
msgid "StremHU Source configuration"
msgstr "A StremHU Source beállításai"

msgctxt "#30110"
msgid "URL"
msgstr "URL"

msgctxt "#30111"
msgid "StremHU Source Kodi integration URL, which you can copy from the interface."
msgstr "A StremHU Source Kodi-integrációs URL-je, amelyet a felületről másolhatsz ki."

msgctxt "#30200"
msgid "Install StremHU player"
msgstr "StremHU lejátszó telepítése"

msgctxt "#30210"
msgid "to TMDb Helper"
msgstr "a TMDb Helperhez"

msgctxt "#30211"
msgid "To use StremHU, you need to install the player in the helper so it appears as a selectable option when starting a movie or series"
msgstr "A StremHU használatához telepíteni kell a lejátszót a TMDb Helperbe / TMDb Bingie Helperbe, hogy film vagy sorozat indításakor választható lehetőségként jelenjen meg."

msgctxt "#30220"
msgid "to TMDb Bingie Helper"
msgstr "a TMDb Bingie Helperhez"

msgctxt "#30032"
msgid "Select stream"
msgstr "Stream kiválasztása"

msgctxt "#30040"
msgid "Missing required setting"
msgstr "Hiányzó kötelező beállítás"

msgctxt "#30042"
msgid "No torrent available"
msgstr "Nincs elérhető torrent"

msgctxt "#30043"
msgid "No torrents are available for this content, or there are no results matching your configured StremHU Source preferences."
msgstr "Ehhez a tartalomhoz nincs elérhető torrent, vagy nincs találat a StremHU Source beállításai alapján."

msgctxt "#30060"
msgid "Resolver addon: call this plugin from another addon/player rule."
msgstr "Resolver kiegészítő: ezt a plugint egy másik kiegészítőből vagy lejátszószabályból hívd meg."

msgctxt "#30072"
msgid "TMDB Helper player rule installed."
msgstr "A TMDb Helper lejátszószabály telepítve."

msgctxt "#30074"
msgid "TMDB Helper player rule install failed."
msgstr "Nem sikerült telepíteni a TMDb Helper lejátszószabályát."

msgctxt "#30075"
msgid "TMDB Helper is not installed."
msgstr "A TMDb Helper nincs telepítve."

msgctxt "#30076"
msgid "Plugin ID is required."
msgstr "A pluginazonosító megadása kötelező."
